<odoo>
    <data>
        
        <record id="view_registros_tree" model="ir.ui.view">
            <field name="name">Servicio a Domicilio</field>
            <field name="model">ctt_sad.registro</field>
            <field name="arch" type="xml">
                <tree edit="0" sample="1">
                    <field name="fecha"/>
<!--                     <field name="barcode" string="Codigo Socio"/>
                    <field name="check_in"/>
                    <field name="state" widget="badge" decoration-danger="state == 'd'" decoration-success="state == 'a'"/> -->
                </tree>
            </field>
        </record>
        
        <record model="ir.actions.act_window" id="action_registros_for_ctt">
            <field name="name">Registros SAD</field>
            <field name="res_model">ctt_sad.registro</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="ctt_sad.view_registros_tree"/>
            <field name="context">{'create':False,'edit':False,'delete':False}</field>
        </record>
        
        <record id="ctt_action_domicilio_tree" model="ir.actions.act_window">
            <field name="name">Servicio a Domicilio</field>
            <field name="res_model">ctt_sad.registro</field>
            <field name="view_mode">tree</field>
            <field name="context">{'create': False}</field>
            <field name="target">main</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_empty_folder">
                    No attendance records to display
                </p><p>
                    Your attendance records will be displayed here.
                </p>
            </field>
        </record>
        
        <menuitem id="menu_ctt_domicilio_root" name="Servicio a Domicilio" web_icon="ctt_sad,static/description/odoo_icon.png" groups=""/>
        <menuitem id="menu_ctt_domicilio_list" name="Servicio a Domicilio" parent="menu_ctt_domicilio_root" sequence="1" action="ctt_action_domicilio_tree"/>
        
        <menuitem id="menu_pos_recolecciones_for_ctt" 
                          name="Servicio a Domicilio" 
                          action="action_registros_for_ctt"
                          parent="base.menu_grant_menu_access" 
                          sequence="150" />
    </data>
</odoo>
