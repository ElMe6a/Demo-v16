        <record id="tree_pos_recolecciones_for_ctt" model="ir.ui.view">
                    <field name="name">Recolecciones</field>
                    <field name="model">torti_config.recolecciones</field>
                    <field name="priority">1001</field>
                    <field name="arch" type="xml">
                        <tree>
